# ── IBM Watsonx.ai Credentials ────────────────────────────────────────
# Get from: https://cloud.ibm.com/iam/apikeys
WATSONX_API_KEY=mAA8sKFKknaKljfbrJjEeoBaqURPRLDb__SktXSMRXw2

# Get from: https://dataplatform.cloud.ibm.com → Your Project → Manage → General
WATSONX_PROJECT_ID=1976f17e-1503-45a5-8e8f-36c2c2f4a06d
# IBM Watsonx.ai endpoint (change region if needed)
# Regions: us-south, eu-de, eu-gb, jp-tok, au-syd
WATSONX_URL=https://au-syd.dai.cloud.ibm.com

# ── Model Configuration ───────────────────────────────────────────────
# Available Granite models:
#   ibm/granite-3-3-8b-instruct     ← Recommended (best balance)
#   ibm/granite-3-2-8b-instruct     ← Alternative
#   ibm/granite-13b-chat-v2         ← Larger, more detailed responses
#   ibm/granite-3-8b-instruct       ← Stable v3
WATSONX_MODEL_ID=Travel Planner Agent

# ── Flask Configuration ───────────────────────────────────────────────
# Generate a secure secret: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=Harshil_TravelPlanner_2026_SecureKey

# Set to "production" when deploying
FLASK_ENV=development

# Port (default: 5000)
PORT=5000
